import socket
import threading
import sys
import tty
import termios
import time

# ==========================================
# [설정] 아두이노 시리얼 모니터에서 확인한 ESP32 IP 입력
# ==========================================
ESP32_IP = '192.168.0.XXX' 
PORT = 8080

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(2.0) # 연결 시도 2초 대기
    sock.connect((ESP32_IP, PORT))
    print(f"[{ESP32_IP}:{PORT}] ESP32 Wi-Fi 직접 접속 성공!")
    sock.settimeout(None) # 연결 후에는 타임아웃 해제
except Exception as e:
    print(f"ESP32 접속 실패. IP 주소와 같은 와이파이인지 확인하세요.\n에러: {e}")
    sys.exit()

active_command = 'x'
running = True

# ---------------------------------------------------------
# 1. 수신 스레드 (TCP 소켓 리딩)
# ---------------------------------------------------------
def read_from_socket():
    global running
    while running:
        try:
            data = sock.recv(1024).decode('utf-8')
            if data:
                # 데이터를 줄바꿈 단위로 쪼개어 출력
                lines = data.split('\n')
                for line in lines:
                    if line.strip():
                        sys.stdout.write(f"\r[ESP32] {line.strip()}\n")
                        sys.stdout.flush()
            else:
                raise Exception("연결이 서버(ESP32)에 의해 종료되었습니다.")
        except Exception as e:
            print(f"\n\n🚨 [수신 에러] ESP32와의 Wi-Fi 연결이 끊겼습니다!\n상세: {e}\n")
            running = False
            break

read_thread = threading.Thread(target=read_from_socket)
read_thread.daemon = True
read_thread.start()

# ---------------------------------------------------------
# 2. 하트비트 스레드
# ---------------------------------------------------------
def send_heartbeat():
    global running
    while running:
        try:
            command_packet = f"<{active_command}>"
            sock.sendall(command_packet.encode())
        except Exception as e:
            print(f"\n\n🚨 [송신 에러] 데이터를 보낼 수 없습니다!\n상세: {e}\n")
            running = False
            break
        time.sleep(0.2) 

heartbeat_thread = threading.Thread(target=send_heartbeat)
heartbeat_thread.daemon = True
heartbeat_thread.start()

# ---------------------------------------------------------
# 3. 키보드 제어부 (기존과 동일)
# ---------------------------------------------------------
def get_char():
    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    try:
        new_settings = termios.tcgetattr(fd)
        new_settings[3] = new_settings[3] & ~termios.ICANON & ~termios.ECHO
        termios.tcsetattr(fd, termios.TCSANOW, new_settings)
        ch = sys.stdin.read(1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
    return ch

print("\n" + "="*40)
print(" 🚀 [버전 4.0] ESP32 직접 연결 통제소 (Wi-Fi)")
print(" - [w] : 전진 (한 번만 누르세요)")
print(" - [s] : 후진")
print(" - [x] : 정지")
print(" - [q] : 프로그램 종료")
print("="*40 + "\n")

try:
    while running:
        char = get_char().lower()
        if char == 'q':
            running = False
            print("\n프로그램을 종료합니다.")
            break
        elif char in ['w', 's', 'x']:
            active_command = char 
except KeyboardInterrupt:
    running = False
    print("\n강제 종료됨.")
finally:
    try:
        sock.sendall(b"<x>")
    except:
        pass
    sock.close()
